## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Restore results
project.assets.json
project.nuget.cache

# Rider / ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/

# Visual Studio Code
.vscode/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MSTest
[Tt]est[Rr]esult*/
*.trx

# Coverage
*.coverage
*.coveragexml

# Publish output
.publish/
[Pp]ublish/
wwwroot/dist/

# Azure / local settings
local.settings.json

# Generated files
Generated\ Files/
*.g.cs
*.g.i.cs

# Backup & temp files
*.bak
*.tmp
*.temp
*.log
~$*
*.dbmdl
*.opendb
*.VC.db
*.VC.VC.opendb

# SQL Server files
*.mdf
*.ldf

# Windows image/file caches
Thumbs.db
ehthumbs.db
Desktop.ini

# OS generated files
.DS_Store

# Node modules (se usi frontend dentro la solution)
node_modules/

# Yarn / npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*

# CMake (se usi C++ con CMake)
CMakeFiles/
CMakeCache.txt
cmake-build-*/
out/build/
out/install/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Package directories
artifacts/

# Optional: keep appsettings tracked, ignore environment-specific overrides
appsettings.Development.json