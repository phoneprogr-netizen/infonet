<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.ProfiloPage"
    Title="Profilo"
    BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <Frame BackgroundColor="#EFB339" CornerRadius="14" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <Image Source="iconprofilo.png"
                               HeightRequest="70"
                               WidthRequest="70"
                               HorizontalOptions="Center" />

                        <Label x:Name="MailLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1D1D1B"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Text="mail@cliente.it" />

                        <Label x:Name="UsernameLabel"
                               FontSize="14"
                               TextColor="#1D1D1B"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Text="Username" />

                        <Label x:Name="CodiceClienteLabel"
                               FontSize="14"
                               TextColor="#1D1D1B"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Text="Codice cliente: -" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="0" CornerRadius="12" HasShadow="False" BackgroundColor="White">
                    <VerticalStackLayout Spacing="0">
                        <Button Text="Modifica profilo"
                                Clicked="OnModificaProfiloClicked"
                                BackgroundColor="White"
                                TextColor="Black"
                                HorizontalOptions="Fill" />
                        <BoxView HeightRequest="1" Opacity="0.3" />

                        <Button Text="Manuale d'uso"
                                Clicked="OnManualeClicked"
                                BackgroundColor="White"
                                TextColor="Black"
                                HorizontalOptions="Fill" />
                        <BoxView HeightRequest="1" Opacity="0.3" />

                        <Button Text="Termini e condizioni"
                                Clicked="OnTerminiClicked"
                                BackgroundColor="White"
                                TextColor="Black"
                                HorizontalOptions="Fill" />
                        <BoxView HeightRequest="1" Opacity="0.3" />

                        <Button Text="Richiesta eliminazione profilo"
                                Clicked="OnDeleteProfileClicked"
                                BackgroundColor="White"
                                TextColor="Black"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Frame>

                <Label x:Name="VersioneLabel"
                       FontSize="12"
                       TextColor="#6B6B6B"
                       HorizontalOptions="Center"
                       Text="Versione -" />
            </VerticalStackLayout>
        </ScrollView>

        <Button
            Grid.Row="1"
            Text="Logout"
            Style="{StaticResource AlertAccentButtonStyle}"
            HeightRequest="50"
            Margin="20"
            CornerRadius="12"
            BackgroundColor="White"
            TextColor="Black"
            Clicked="OnLogoutClicked"/>
    </Grid>

</ContentPage>
