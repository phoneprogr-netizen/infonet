<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppInfonet.Pages.BersaglioMapEditPage"
             Title="Modifica bersaglio su mappa">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <Grid Grid.Row="0"
              Padding="12"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">
            <Label x:Name="TargetNameLabel"
                   Text="..."
                   FontSize="16"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation" />
        </Grid>
        
        <WebView x:Name="MapWebView"
                 Grid.Row="0"
                 Navigating="OnWebViewNavigating" />

        <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="12" ColumnSpacing="10">
            <Button Text="Annulla" Clicked="OnCancelClicked" />
            <Button Grid.Column="1" Text="Salva" Clicked="OnSaveClicked" />
        </Grid>

    </Grid>
</ContentPage>
