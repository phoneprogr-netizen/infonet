<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.DashboardPage"
    BackgroundColor="#F1F4F9">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- TITOLO -->
            <Label Text="Dashboard"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111111"/>

            <!-- HEADER BENVENUTO -->
            <Frame Padding="15"
                   CornerRadius="15"
                   HasShadow="False"
                   BorderColor="#D9E0EA"
                   BackgroundColor="White">

                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <!-- Testo Benvenuto -->
                    <Label Text="{Binding UserEmail, StringFormat='Ciao {0}'}"
                           FontSize="18"
                           TextColor="#111111"
                           VerticalOptions="Center"/>

                    <!-- Bottone Profilo -->
                    <ImageButton Grid.Column="1"
                                 Source="iconprofilo.png"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 BackgroundColor="Transparent"
                                 Clicked="OnProfileClicked"/>
                </Grid>
            </Frame>

            <!-- BOTTONI GRANDI VERTICALI -->
            <VerticalStackLayout Spacing="15">

                <!-- DISPOSITIVI -->
                <Frame CornerRadius="20"
                       HasShadow="False"
                       BorderColor="#D9E0EA"
                       Padding="20"
                       HeightRequest="80"
                       BackgroundColor="White">

                    <Grid ColumnDefinitions="Auto,*"
                          VerticalOptions="Center">

                        <Label Text="📱"
                               FontSize="36"
                               TextColor="#2563EB"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1"
                               Text="Dispositivi"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               VerticalOptions="Center"
                               Margin="15,0,0,0"/>
                    </Grid>

                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDispositiviTapped"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- ALLARMI -->
                <Frame CornerRadius="20"
                       HasShadow="False"
                       BorderColor="#D9E0EA"
                       Padding="20"
                       HeightRequest="80"
                       BackgroundColor="White">

                    <Grid ColumnDefinitions="Auto,*"
                          VerticalOptions="Center">

                        <Label Text="🚨"
                               FontSize="36"
                               TextColor="#2563EB"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1"
                               Text="Allarmi"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               VerticalOptions="Center"
                               Margin="15,0,0,0"/>
                    </Grid>

                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAllarmiTapped"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- BERSAGLI -->
                <Frame CornerRadius="20"
                       HasShadow="False"
                       BorderColor="#D9E0EA"
                       Padding="20"
                       HeightRequest="80"
                       BackgroundColor="White">

                    <Grid ColumnDefinitions="Auto,*"
                          VerticalOptions="Center">

                        <Label Text="📍"
                               FontSize="36"
                               TextColor="#2563EB"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1"
                               Text="Bersagli"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               VerticalOptions="Center"
                               Margin="15,0,0,0"/>
                    </Grid>

                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBersagliTapped"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- TRAGITTI -->
                <Frame CornerRadius="20"
                       HasShadow="False"
                       BorderColor="#D9E0EA"
                       Padding="20"
                       HeightRequest="80"
                       BackgroundColor="White">

                    <Grid ColumnDefinitions="Auto,*"
                          VerticalOptions="Center">

                        <Label Text="🛣"
                               FontSize="36"
                               TextColor="#2563EB"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1"
                               Text="Tragitti"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               VerticalOptions="Center"
                               Margin="15,0,0,0"/>
                    </Grid>

                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTragittiTapped"/>
                    </Frame.GestureRecognizers>
                </Frame>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
