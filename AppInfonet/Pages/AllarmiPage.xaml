<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.AllarmiPage"
    Title="Allarmi">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <Button
            Grid.Row="0"
            Text="Storico allarmi"
            HorizontalOptions="Start"
            Clicked="OnStoricoClicked" />

        <CollectionView
            Grid.Row="1"
            Margin="0,12,0,0"
            ItemsSource="{Binding Allarmi}"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <Label Text="Nessun allarme disponibile"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6" Padding="12" CornerRadius="12" HasShadow="True">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding MessaggioDisplay}" FontAttributes="Bold" FontSize="16" />

                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{Binding DataOraDisplay}" FontSize="13" />
                                <Label Grid.Column="1" Text="Stato" FontSize="13" />
                                <Label Grid.Column="2" Text="{Binding StatoDisplay}" FontSize="13" FontAttributes="Bold" />
                            </Grid>

                            <Button Text="Apri su mappa"
                                    Clicked="OnApriMappaClicked"
                                    CommandParameter="{Binding IdTestataAllarme}" />

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Button Grid.Column="0"
                                        Text="✕"
                                        Clicked="OnCloseEventClicked"
                                        CommandParameter="{Binding IdTestataAllarme}" />
                                <Button Grid.Column="1"
                                        Text="🔕"
                                        Clicked="OnSnoozeEventClicked"
                                        CommandParameter="{Binding IdTestataAllarme}" />
                                <Button Grid.Column="2"
                                        Text="🎧"
                                        Clicked="OnSendToOperationCenterClicked"
                                        CommandParameter="{Binding IdTestataAllarme}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
