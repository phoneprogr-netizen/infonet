<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.DispositivoDetPage"
    Title="Dettaglio dispositivo">

    <Grid RowDefinitions="Auto,*,Auto,Auto"
          Padding="16">

        <!-- Header: nome mezzo / targa + indirizzo -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="{Binding DisplayName}"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Label Text="{Binding FullAddress}"
                   FontSize="12"
                   TextColor="Gray"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <!-- Mappa OpenStreetMap -->
        <WebView x:Name="DeviceMapWebView"
                 Grid.Row="1"
                 Margin="0,8,0,8" />

        <!-- Stato sotto la mappa -->
        <HorizontalStackLayout Grid.Row="2"
                               Spacing="16">
            <Label Text="{Binding QuadroDisplay}"
                   FontSize="14" />
            <Label Text="{Binding SpeedDisplay}"
                   FontSize="14" />
            <Label Text="{Binding BatteryDisplay}"
                   FontSize="14" />
        </HorizontalStackLayout>

        <!-- Bottone Apri in Maps -->
        <Button Grid.Row="3"
                Margin="0,8,0,0"
                Text="Apri in Maps"
                HorizontalOptions="Center"
                Clicked="OnOpenInMapsClicked" />

    </Grid>
</ContentPage>