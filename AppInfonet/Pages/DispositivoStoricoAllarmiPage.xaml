<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.DispositivoStoricoAllarmiPage"
    Title="Storico allarmi"
    BackgroundColor="#F1F4F9">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <Button
            Grid.Row="0"
            Text="Storico allarmi"
            HorizontalOptions="Fill"
            BackgroundColor="White"
            TextColor="Black"
            CornerRadius="22" />

        <CollectionView
            Grid.Row="1"
            Margin="0,12,0,0"
            ItemsSource="{Binding StoricoAllarmi}"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <Frame
                    Margin="0,6"
                    Padding="14"
                    CornerRadius="12"
                    HasShadow="False"
                    BackgroundColor="White"
                    BorderColor="#D1D5DB">
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Storico allarmi in arrivo"
                            FontAttributes="Bold"
                            FontSize="16"
                            TextColor="Black" />
                        <Label
                            Text="Qui vedrai lo storico degli allarmi del dispositivo selezionato."
                            FontSize="13"
                            TextColor="Black" />
                        <Label
                            Text="Dispositivo:"
                            FontSize="13"
                            TextColor="Black" />
                        <Label
                            Text="{Binding DeviceName}"
                            FontAttributes="Bold"
                            FontSize="14"
                            TextColor="Black" />
                    </VerticalStackLayout>
                </Frame>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Margin="0,6"
                        Padding="12"
                        CornerRadius="12"
                        HasShadow="True"
                        BackgroundColor="White"
                        BorderColor="Black">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="{Binding Titolo}"
                                FontAttributes="Bold"
                                FontSize="16"
                                TextColor="Black" />
                            <Label
                                Text="{Binding DataOra}"
                                FontSize="13"
                                TextColor="Black" />
                            <Label
                                Text="{Binding Stato}"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="Black" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
