<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.DispositiviPage"
    Title="Dispositivi"
    BackgroundColor="#F1F4F9">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="mappa_white.svg"
            Order="Primary"
            Priority="0"
            Clicked="OnMapButtonClicked" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid RowDefinitions="*"
              Padding="16"
              BackgroundColor="#F1F4F9">

            <!-- Lista dispositivi -->
            <CollectionView
    x:Name="DevicesCollectionView"
    Grid.Row="0"
    ItemsSource="{Binding Devices}"
    SelectionMode="None"
    BackgroundColor="#F1F4F9">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,6"
                   Padding="12"
                   CornerRadius="12"
                   HasShadow="True"
                   BackgroundColor="White"
                   BorderColor="Black">

                            <!-- 👇 GESTURE TAP SULL’INTERO FRAME -->
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                        Tapped="OnDeviceTapped" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="4">

                                <!-- Nome dispositivo / mezzo -->
                                <Label Text="{Binding DisplayName}"
                           FontAttributes="Bold"
                           FontSize="Medium"
                           TextColor="#EFB339" />

                                <!-- Data/ora ultimo fix -->
                                <Label Text="{Binding LastFixDisplay}"
                           FontSize="Small"
                           TextColor="Black" />

                                <!-- Codice periferica -->
                                <Label Text="{Binding COD_PERIF}"
                           FontSize="Small"
                           TextColor="Black" />

                                <!-- Indirizzo -->
                                <Label Text="{Binding FullAddress}"
                           FontSize="Small"
                           TextColor="Black"
                           LineBreakMode="TailTruncation" />

                                <!-- Riga con quadro, velocità, batteria -->
                                <HorizontalStackLayout Margin="0,8,0,0" Spacing="16">
                                    <Label Text="{Binding QuadroDisplay}"
                               FontSize="Small"
                               TextColor="Black" />
                                    <Label Text="{Binding SpeedDisplay}"
                               FontSize="Small"
                               TextColor="Black" />
                                    <Label Text="{Binding BatteryDisplay}"
                               FontSize="Small"
                               TextColor="Black" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ContentPage.Content>
</ContentPage>
