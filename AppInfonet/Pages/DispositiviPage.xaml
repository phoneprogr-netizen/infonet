<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppInfonet.Pages.DispositiviPage"
    Title="Dispositivi">

    <ContentPage.Content>
        <Grid RowDefinitions="Auto,*"
              Padding="16">

            <HorizontalStackLayout Grid.Row="0"
                       VerticalOptions="Center"
                       Spacing="8">

                <Label Text="Dispositivi"
           FontSize="24"
           FontAttributes="Bold"
           HorizontalOptions="StartAndExpand" />

                <ImageButton
                Source="mappa.svg"
                WidthRequest="28"
                HeightRequest="28"
                Padding="6"
                BackgroundColor="{StaticResource BrandYellowDark}"
                CornerRadius="16"
                Clicked="OnMapButtonClicked" /> 

            </HorizontalStackLayout>

            <!-- Lista dispositivi -->
            <CollectionView
    x:Name="DevicesCollectionView"
    Grid.Row="1"
    Margin="0,12,0,0"
    ItemsSource="{Binding Devices}"
    SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,6"
                   Padding="12"
                   CornerRadius="12"
                   HasShadow="True">

                            <!-- 👇 GESTURE TAP SULL’INTERO FRAME -->
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                        Tapped="OnDeviceTapped" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="4">

                                <!-- Nome dispositivo / mezzo -->
                                <Label Text="{Binding DisplayName}"
                           FontAttributes="Bold"
                           FontSize="Medium" />

                                <!-- Data/ora ultimo fix -->
                                <Label Text="{Binding LastFixDisplay}"
                           FontSize="Small"
                           TextColor="Gray" />

                                <!-- Codice periferica -->
                                <Label Text="{Binding COD_PERIF}"
                           FontSize="Small" />

                                <!-- Indirizzo -->
                                <Label Text="{Binding FullAddress}"
                           FontSize="Small"
                           LineBreakMode="TailTruncation" />

                                <!-- Riga con quadro, velocità, batteria -->
                                <HorizontalStackLayout Margin="0,8,0,0" Spacing="16">
                                    <Label Text="{Binding QuadroDisplay}"
                               FontSize="Small" />
                                    <Label Text="{Binding SpeedDisplay}"
                               FontSize="Small" />
                                    <Label Text="{Binding BatteryDisplay}"
                               FontSize="Small" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ContentPage.Content>
</ContentPage>
