<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppInfonet.Pages.BersagliMapPage"
             Title="Mappa bersagli">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <Grid Grid.Row="0"
              Padding="12"
              BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceLight}, Dark={StaticResource ColorSurfaceDark}}">
            <Label Text="Tutti i bersagli"
                   FontSize="16"
                   FontAttributes="Bold" />
        </Grid>

        <WebView x:Name="MapWebView"
                 Grid.Row="1"
                 Navigating="OnWebViewNavigating" />
    </Grid>
</ContentPage>
